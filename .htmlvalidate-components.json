{
  "extends": ["html-validate:recommended"],
  "root": true,
  "rules": {
    "element-permitted-content": "off",
    "element-permitted-parent": "off",
    "unique-landmark": "off",
    "no-dup-id": "off",
    "void-style": "off",
    "no-inline-style": "off",
  "wcag/h30": "error",
  "wcag/h32": "error",
  "wcag/h37": "error",
  "wcag/h67": "error",
    "close-order": "off",
    "attr-spacing": "off",
    "no-trailing-whitespace": "off"
  }
}
