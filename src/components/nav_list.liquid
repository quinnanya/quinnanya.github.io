<p>MENU FOO</p>
{% assign navigation = site.data.navigation[include.nav] %}

<nav class="nav__list" aria-label="{{ sidebar.title | default: 'Sidebar navigation' }}">
  {% if sidebar.title %}<h3 class="nav__title">{{ sidebar.title }}</h3>{% endif %}
  {%- assign ac_id = 'ac-toc' -%}
  {%- if sidebar.title %}
    {%- assign ac_id = ac_id | append: '-' | append: sidebar.title | slugify -%}
  {%- endif -%}
  <input id="{{ ac_id }}" name="accordion-toc" type="checkbox">
  <label for="{{ ac_id }}">{{ site.data.ui-text[site.locale].menu_label | default: "Toggle Menu" }}</label>
  <ul class="nav__items">
    {% for nav in header %}
      <li>
        {% if nav.url %}
          <a href="{{ nav.url | relative_url }}"><span class="nav__sub-title">{{ nav.title }}</span></a>
        {% else %}
          <span class="nav__sub-title">{{ nav.title }}</span>
        {% endif %}

        {% if nav.children != null %}
        <ul>
          {% for child in nav.children %}
            <li><a href="{{ child.url | relative_url }}"{% if child.url == url %} class="active"{% endif %}>{{ child.title }}</a></li>
          {% endfor %}
        </ul>
        {% endif %}
      </li>
    {% endfor %}
  </ul>
</nav>
