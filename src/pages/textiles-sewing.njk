<script>
  (function () {
    var tagFilter = document.getElementById("sewing-tag-filter");
    var items = Array.prototype.slice.call(document.querySelectorAll("[data-sewing-item]"));
    var lightbox = document.getElementById("sewing-lightbox");
    var closeButton = document.getElementById("sewing-lightbox-close");
    var lightboxTitle = document.getElementById("sewing-lightbox-title");
    var lightboxImage = document.getElementById("sewing-lightbox-image");
    var lightboxDate = document.getElementById("sewing-lightbox-date");
    var lightboxPattern = document.getElementById("sewing-lightbox-pattern");
    var lightboxNotes = document.getElementById("sewing-lightbox-notes");
    var countLabel = document.getElementById("sewing-filter-count");
    var previousActiveElement = null;

    function splitTags(value) {
      return (value || "")
        .split(",")
        .map(function (tag) { return tag.trim(); })
        .filter(Boolean);
    }

    function populateFilter() {
      var uniqueTags = new Set();

      items.forEach(function (item) {
        splitTags(item.getAttribute("data-tags")).forEach(function (tag) {
          uniqueTags.add(tag);
        });
      });

      Array.from(uniqueTags)
        .sort(function (a, b) { return a.localeCompare(b); })
        .forEach(function (tag) {
          var option = document.createElement("option");
          option.value = tag;
          option.textContent = tag;
          tagFilter.appendChild(option);
        });
    }

    function applyFilter() {
      var selectedTag = tagFilter.value;
      var visibleCount = 0;

      items.forEach(function (item) {
        var tags = splitTags(item.getAttribute("data-tags"));
        var visible = !selectedTag || tags.indexOf(selectedTag) > -1;
        item.hidden = !visible;
        if (visible) {
          visibleCount += 1;
        }
      });

      if (countLabel) {
        countLabel.textContent = "Showing " + visibleCount + " item" + (visibleCount === 1 ? "" : "s") + (selectedTag ? " for " + selectedTag : "");
      }
    }

    function loadProgressiveImage(img) {
      var src = img.getAttribute("data-sewing-src");
      if (!src) {
        return;
      }

      img.src = src;
      img.removeAttribute("data-sewing-src");
    }

    function initProgressiveImages() {
      var deferredImages = Array.prototype.slice.call(document.querySelectorAll("img[data-sewing-src]"));

      if (!deferredImages.length) {
        return;
      }

      if (!("IntersectionObserver" in window)) {
        deferredImages.forEach(loadProgressiveImage);
        return;
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) {
            return;
          }

          loadProgressiveImage(entry.target);
          observer.unobserve(entry.target);
        });
      }, { rootMargin: "200px 0px" });

      deferredImages.forEach(function (img) {
        observer.observe(img);
      });
    }

    function openLightbox(data) {
      previousActiveElement = document.activeElement;
      lightboxTitle.textContent = data.name || "Sewing project";
      lightboxImage.src = data.image || "";
      lightboxImage.alt = data.name || "Sewing project";
      lightboxDate.textContent = data.date || "—";
      lightboxPattern.textContent = data.pattern || "—";
      lightboxNotes.textContent = data.notes || "—";
      lightbox.classList.add("is-open");
      lightbox.hidden = false;
      lightbox.setAttribute("aria-hidden", "false");
      closeButton.focus();
      document.body.style.overflow = "hidden";
    }

    function closeLightbox() {
      lightbox.classList.remove("is-open");
      lightbox.hidden = true;
      lightbox.setAttribute("aria-hidden", "true");
      lightboxImage.src = "";
      document.body.style.overflow = "";
      if (previousActiveElement && typeof previousActiveElement.focus === "function") {
        previousActiveElement.focus();
      }
    }

    document.addEventListener("click", function (event) {
      var trigger = event.target.closest("[data-sewing-open]");

      if (trigger) {
        openLightbox({
          name: trigger.getAttribute("data-name"),
          image: trigger.getAttribute("data-image"),
          date: trigger.getAttribute("data-date"),
          pattern: trigger.getAttribute("data-pattern"),
          notes: trigger.getAttribute("data-notes")
        });
        return;
      }

      if (lightbox.classList.contains("is-open") && (event.target === lightbox || event.target === closeButton)) {
        closeLightbox();
      }
    });

    document.addEventListener("keydown", function (event) {
      if (lightbox.classList.contains("is-open") && event.key === "Escape") {
        closeLightbox();
      }
    });

    tagFilter.addEventListener("change", applyFilter);

    closeLightbox();
    initProgressiveImages();
    populateFilter();
    applyFilter();
  })();
</script>
